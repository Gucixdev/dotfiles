{
  "version": 2,
  "editor": {
    "status_bar": {
      "left": [
        "{remote}",
        "{cursor}",
        "{cursor_count}",
        "{messages}",
        "{git_statusbar:branch}"
      ],
      "right": [
        "{language}",
        "{lsp}",
        "{warnings}",
        "{update}"
      ]
    }
  },
  "keybindings": [
    {
      "key": "ctrl+shift+d",
      "action": "toggle_diagnostics_panel"
    }
  ],
  "lsp": {
    "c": {
      "enabled": true,
      "auto_start": true,
      "process_limits": {
        "max_memory_percent": 50,
        "max_cpu_percent": 90,
        "enabled": true
      }
    },
    "bash": {
      "enabled": true,
      "auto_start": true,
      "process_limits": {
        "max_memory_percent": 50,
        "max_cpu_percent": 90,
        "enabled": true
      }
    }
  },
  "plugins": {
    "vi_mode": {
      "enabled": true,
      "settings": {
        "autoStart": true
      }
    }
  }
}